# ─────────────────────────────────────────────────────────────
#  Customer Support MCP – Environment Variables
#  Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq API (primary LLM – free tier) ───────────────────────────────────────
# Get your FREE key at: https://console.groq.com
# Leave blank to run in Ollama-only mode.
GROQ_API_KEY=your_groq_api_key_here

# Free-tier Groq models (pick one):
#   llama-3.1-8b-instant     – fast, great for support tasks (default)
#   llama-3.3-70b-versatile  – more capable, still free
#   mixtral-8x7b-32768       – large context window
#   gemma2-9b-it             – Google Gemma 2
GROQ_MODEL=llama-3.1-8b-instant

# Comma-separated fallback chain (override the default order):
# GROQ_FALLBACK_MODELS=llama-3.1-8b-instant,gemma2-9b-it,mixtral-8x7b-32768

# ── Ollama (fallback LLM – local, unlimited, no API key required) ─────────────
# Requires Ollama running locally or via docker-compose.
# Install: https://ollama.com/download
# Pull model: ollama pull llama3.2
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── LangSmith (optional – observability & tracing) ────────────────────────────
# Get a free key at: https://smith.langchain.com
# Leave blank to disable tracing.
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=customer-support-mcp

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Maximum AI requests per customer per window.
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ── Server ─────────────────────────────────────────────────────────────────────
SERVER_NAME=CustomerSupportMCP
LOG_LEVEL=INFO
# LOG_FORMAT=json   # Uncomment for machine-parseable JSON logs (CI/CD, Docker)

