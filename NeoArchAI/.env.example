# NeoArchAI Environment Configuration
# Copy this to .env and fill in your values

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose ONE provider below. Leave others commented.

# ── Option 1: Groq (FREE) — https://console.groq.com ─────────────────────────
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
# Other free Groq models: llama-3.1-8b-instant | mixtral-8x7b-32768 | gemma2-9b-it

# ── Option 2: Google Gemini (FREE) — https://aistudio.google.com ─────────────
# pip install langchain-google-genai
# GEMINI_API_KEY=your_gemini_api_key_here
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-flash
# Other models: gemini-1.5-pro | gemini-2.0-flash-exp

# ── Option 3: Together AI (FREE credits) — https://api.together.xyz ──────────
# pip install langchain-openai
# TOGETHER_API_KEY=your_together_api_key_here
# LLM_PROVIDER=together
# LLM_MODEL=meta-llama/Llama-3-70b-chat-hf
# Other models: mistralai/Mixtral-8x7B-Instruct-v0.1 | Qwen/Qwen2.5-72B-Instruct-Turbo

# ── Option 4: Cohere (FREE tier) — https://dashboard.cohere.com ──────────────
# pip install langchain-cohere
# COHERE_API_KEY=your_cohere_api_key_here
# LLM_PROVIDER=cohere
# LLM_MODEL=command-r-plus
# Other models: command-r | command

# ── Option 5: OpenAI ─────────────────────────────────────────────────────────
# pip install langchain-openai
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# Other models: gpt-4o | gpt-3.5-turbo

# ── Option 6: Ollama (fully local, 100% free) — https://ollama.ai ────────────
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.2
# Other models: mistral | codellama | phi3 | gemma2

# ── Option 7: OpenAI-compatible (LM Studio, vLLM, Anyscale, etc.) ────────────
# pip install langchain-openai
# LLM_PROVIDER=openai-compat
# OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPAT_API_KEY=none
# LLM_MODEL=local-model

# ── Option 8: No LLM (algorithmic fallback, no API key needed) ───────────────
# LLM_PROVIDER=none

# ─── Application Settings ─────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
OUTPUT_DIR=output
MAX_CONCURRENT_DESIGNS=5
DEBUG=false

# ─── MCP Server ───────────────────────────────────────────────────────────────
MCP_PORT=8001
